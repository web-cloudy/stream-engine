# Broadcasting Engine (Part 2) configuration
# Copy this file to .env and adjust as needed.

# Secret key (change in production!)
SECRET_KEY=change-me-in-production

# Where received segments/recordings are stored on disk
TRANSCODE_TEMP_DIR=./transcode_temp

# FFmpeg path (used only for "download recording as MP4"). 'ffmpeg' = auto-detect from PATH.
FFMPEG_PATH=ffmpeg

# Server settings
HOST=0.0.0.0
PORT=5000
DEBUG=true
