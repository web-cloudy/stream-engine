# Web Viewer (Part 3) configuration
# Copy this file to .env and adjust as needed.

# Base URL of the Broadcasting Engine (Part 2).
# IMPORTANT: this URL is used by the VIEWER'S BROWSER, so when viewers are on
# other machines use the engine's LAN IP / public host (e.g. http://192.168.1.50:5000),
# not localhost.
ENGINE_URL=http://localhost:5000

# Server settings for this viewer web app
HOST=0.0.0.0
PORT=8080
DEBUG=true
